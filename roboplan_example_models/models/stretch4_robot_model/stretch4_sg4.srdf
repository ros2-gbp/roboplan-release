<?xml version="1.0"?>
<robot name="stretch">
  <group name="stretch4_arm">
    <joint name="mobile_base_planar_joint"/>
    <joint name="lift_joint"/>
    <joint name="arm_l1_joint"/>
    <joint name="wrist_yaw_joint"/>
    <joint name="wrist_pitch_joint"/>
    <joint name="wrist_roll_joint"/>
  </group>

  <group_state group="stretch4_arm" name="home">
    <joint name="mobile_base_planar_joint" value="0.0 0.0 0.0"/>
    <joint name="lift_joint" value="0.5"/>
    <joint name="arm_l1_joint" value="0.065"/>
    <joint name="wrist_yaw_joint" value="0.0"/>
    <joint name="wrist_pitch_joint" value="0.0"/>
    <joint name="wrist_roll_joint" value="0.0"/>
  </group_state>

  <disable_collisions link1="arm_l0_link" link2="arm_l1_link" reason="Adjacent"/>
  <disable_collisions link1="arm_l0_link" link2="lift_link" reason="Adjacent"/>
  <disable_collisions link1="arm_l1_link" link2="arm_l2_link" reason="Adjacent"/>
  <disable_collisions link1="arm_l2_link" link2="arm_l3_link" reason="Adjacent"/>
