  <disable_collisions link1="gripper_finger_left_link" link2="wrist_roll_link" reason="Never"/>
  <disable_collisions link1="gripper_finger_right_link" link2="wrist_roll_link" reason="Never"/>
  <disable_collisions link1="gripper_finger_left_link" link2="tool_attachment_site_link" reason="Never"/>
  <disable_collisions link1="gripper_finger_right_link" link2="tool_attachment_site_link" reason="Never"/>
  <disable_collisions link1="arm_l4_link" link2="wrist_yaw_link" reason="Never"/>
</robot>
