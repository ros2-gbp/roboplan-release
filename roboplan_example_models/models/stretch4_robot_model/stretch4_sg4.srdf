  <disable_collisions link1="grasp_center_link" link2="quick_connect_interface_link" reason="Adjacent"/>
  <disable_collisions link1="gripper_camera_link" link2="wrist_roll_link" reason="Adjacent"/>
  <disable_collisions link1="gripper_finger_left_link" link2="gripper_fingertip_left_link" reason="Adjacent"/>
  <disable_collisions link1="gripper_finger_left_link" link2="quick_connect_interface_link" reason="Adjacent"/>
  <disable_collisions link1="gripper_finger_right_link" link2="gripper_fingertip_right_link" reason="Adjacent"/>
  <disable_collisions link1="gripper_finger_right_link" link2="quick_connect_interface_link" reason="Adjacent"/>
  <disable_collisions link1="lift_link" link2="mast_link" reason="Adjacent"/>
  <disable_collisions link1="quick_connect_interface_link" link2="tool_attachment_site_link" reason="Adjacent"/>
  <disable_collisions link1="tool_attachment_site_link" link2="wrist_roll_link" reason="Adjacent"/>
  <disable_collisions link1="wrist_aruco_link" link2="wrist_link" reason="Adjacent"/>
  <disable_collisions link1="wrist_link" link2="wrist_reflector_link" reason="Adjacent"/>
  <disable_collisions link1="wrist_link" link2="wrist_yaw_link" reason="Adjacent"/>
  <disable_collisions link1="wrist_pitch_link" link2="wrist_roll_link" reason="Adjacent"/>
  <disable_collisions link1="wrist_pitch_link" link2="wrist_yaw_link" reason="Adjacent"/>
  <disable_collisions link1="base_link" link2="lift_link" reason="Never"/>
  <disable_collisions link1="arm_l1_link" link2="lift_link" reason="Never"/>
  <disable_collisions link1="arm_l2_link" link2="lift_link" reason="Never"/>
  <disable_collisions link1="arm_l0_link" link2="arm_l2_link" reason="Never"/>
