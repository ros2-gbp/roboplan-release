  <disable_collisions link1="grasp_center_link" link2="gripper_finger_left_link" reason="Never"/>
  <disable_collisions link1="grasp_center_link" link2="gripper_fingertip_left_link" reason="Never"/>
  <disable_collisions link1="grasp_center_link" link2="gripper_finger_right_link" reason="Never"/>
