  <disable_collisions link1="aruco_fingertip_right_link" link2="gripper_fingertip_right_link" reason="Adjacent"/>
  <disable_collisions link1="base_link" link2="head_link" reason="Adjacent"/>
  <disable_collisions link1="base_link" link2="mast_link" reason="Adjacent"/>
