function(_roboplan_resolve_macos_patch_file file result)
  set(_patch_file "${file}")
  if(IS_SYMLINK "${_patch_file}")
    file(READ_SYMLINK "${_patch_file}" _symlink_target)
    if(IS_ABSOLUTE "${_symlink_target}")
      set(${result} "" PARENT_SCOPE)
      return()
    endif()
    get_filename_component(_symlink_dir "${_patch_file}" DIRECTORY)
    set(_patch_file "${_symlink_dir}/${_symlink_target}")
  endif()

  set(${result} "${_patch_file}" PARENT_SCOPE)
endfunction()

function(_roboplan_add_macos_rpath file rpath)
  _roboplan_resolve_macos_patch_file("${file}" _patch_file)
  if(NOT _patch_file OR NOT EXISTS "${_patch_file}")
    return()
  endif()

  execute_process(
    COMMAND otool -l "${_patch_file}"
    OUTPUT_VARIABLE _otool_output
    ERROR_QUIET
    RESULT_VARIABLE _otool_result
  )
  if(NOT _otool_result EQUAL 0)
    return()
  endif()

  string(FIND "${_otool_output}" "path ${rpath} (offset" _existing_rpath)
  if(_existing_rpath GREATER_EQUAL 0)
    return()
  endif()

  execute_process(
    COMMAND chmod u+w "${_patch_file}"
    COMMAND_ERROR_IS_FATAL ANY
  )
  execute_process(
    COMMAND "@ROBOPLAN_UNIFIED_INSTALL_NAME_TOOL@" -add_rpath "${rpath}" "${_patch_file}"
    COMMAND_ERROR_IS_FATAL ANY
  )
endfunction()

file(GLOB_RECURSE _roboplan_extensions "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/roboplan/*.so")
foreach(_file IN LISTS _roboplan_extensions)
  _roboplan_add_macos_rpath("${_file}" "@loader_path/../../lib")
endforeach()

file(GLOB _roboplan_libraries "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/lib/*.dylib")
foreach(_file IN LISTS _roboplan_libraries)
  _roboplan_add_macos_rpath("${_file}" "@loader_path")
endforeach()
